{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/backlog.v1.schema.json",
  "title": "Consulting Revenue Platform Backlog V1 Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project",
    "execution",
    "categories",
    "stories",
    "phases"
  ],
  "properties": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "description",
        "owner_profile_context"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "owner_profile_context": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "primary_skills",
            "target_language",
            "target_outcome"
          ],
          "properties": {
            "primary_skills": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "target_language": {
              "type": "string",
              "const": "Go"
            },
            "target_outcome": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recommended_method",
        "definition_of_done",
        "global_constraints",
        "story_template_contract"
      ],
      "properties": {
        "recommended_method": {
          "type": "string",
          "minLength": 1
        },
        "definition_of_done": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "global_constraints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "story_template_contract": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required_fields",
            "agent_rules"
          ],
          "properties": {
            "required_fields": {
              "type": "array",
              "minItems": 10,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "agent_rules": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^CAT-[A-Z]$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "stories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/story"
      }
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "story_ids"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^PHASE-[0-9]+$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "story_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[A-Z]-[0-9]{2}$"
            },
            "uniqueItems": true
          }
        }
      }
    }
  },
  "$defs": {
    "endpoint": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "method",
        "path"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST",
            "PUT",
            "PATCH",
            "DELETE"
          ]
        },
        "path": {
          "type": "string",
          "pattern": "^/"
        },
        "auth": {
          "type": "string"
        }
      }
    },
    "story": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "category",
        "title",
        "description",
        "scope",
        "out_of_scope",
        "dependencies",
        "api_contract",
        "data_contract",
        "implementation_notes",
        "security_privacy",
        "edge_cases",
        "acceptance_criteria",
        "test_plan",
        "deliverables",
        "estimate_points",
        "priority"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z]-[0-9]{2}$"
        },
        "category": {
          "type": "string",
          "pattern": "^CAT-[A-Z]$"
        },
        "title": {
          "type": "string",
          "minLength": 8
        },
        "description": {
          "type": "string",
          "minLength": 12
        },
        "scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "out_of_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z]-[0-9]{2}$"
          },
          "uniqueItems": true
        },
        "api_contract": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "endpoints": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/endpoint"
              }
            }
          }
        },
        "data_contract": {
          "type": "object",
          "additionalProperties": true
        },
        "implementation_notes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "security_privacy": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "edge_cases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "test_plan": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "deliverables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "estimate_points": {
          "type": "integer",
          "minimum": 1,
          "maximum": 13
        },
        "priority": {
          "type": "string",
          "enum": [
            "P0",
            "P1",
            "P2"
          ]
        }
      }
    }
  }
}
