# Runtime environment: local | development | staging | production
APP_ENV=local

# HTTP server settings
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT_SEC=10
HTTP_WRITE_TIMEOUT_SEC=10
HTTP_IDLE_TIMEOUT_SEC=60
HTTP_SHUTDOWN_TIMEOUT_SEC=10

# Maximum JSON/body size for POST/PUT/PATCH (bytes, minimum 4096; default 4194304 = 4 MiB)
# HTTP_MAX_REQUEST_BODY_BYTES=4194304

# Retention (operational tables only; invoices/ledger untouched)
# RETENTION_AUDIT_LOG_DAYS=365
# RETENTION_WEBHOOK_EVENT_DAYS=90
# RETENTION_WORKER_ENABLED=false
# RETENTION_WORKER_POLL_INTERVAL_SEC=3600

# JWT_ACCESS_TTL_MIN=15
# JWT_REFRESH_TTL_DAYS=7

# Required in production
# DATABASE_URL=postgres://user:pass@host:5432/database
# JWT_SIGNING_KEY=replace-with-strong-key
# STRIPE_WEBHOOK_SECRET=whsec_replace
